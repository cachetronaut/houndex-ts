{
  "name": "@houndex/cli",
  "version": "0.1.0",
  "description": "Operator + CI surface for the framework verification engine: init, doctor, ingest, ask, verify, eval over a configured storage adapter. The per-transaction verifier is the @houndex/evals library.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./engine": "./src/engine.ts"
  },
  "bin": {
    "houndex": "./bin/houndex.mjs"
  },
  "files": [
    "src",
    "bin"
  ],
  "scripts": {
    "lint": "biome lint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "houndex": "tsx src/cli.ts"
  },
  "dependencies": {
    "@houndex/core": "workspace:*",
    "@houndex/evals": "workspace:*",
    "@houndex/storage-local": "workspace:*",
    "commander": "^12.1.0",
    "zod": "^3.24.1"
  },
  "optionalDependencies": {
    "@houndex/storage-convex": "workspace:*",
    "@houndex/storage-supabase": "workspace:*"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "vitest": "^2.1.8"
  }
}
