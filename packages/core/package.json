{
  "name": "@houndex/core",
  "version": "0.1.0",
  "description": "Core contracts for a storage-decoupled, last-mile RAG framework: schemas, output envelopes, tenant context, provider ports, and the storage adapter interface.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schemas": "./src/schemas/index.ts",
    "./providers": "./src/providers/index.ts",
    "./storage": "./src/storage/index.ts",
    "./tenant": "./src/tenant.ts",
    "./identity": "./src/identity.ts",
    "./models": "./src/models.ts",
    "./observability": "./src/observability.ts"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "lint": "biome lint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@noble/hashes": "^2.2.0",
    "zod": "^3.24.1"
  },
