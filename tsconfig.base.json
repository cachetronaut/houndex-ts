{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "houndex": ["src/index.ts"],
      "houndex/core": ["packages/core/src/index.ts"],
      "houndex/schemas": ["packages/core/src/schemas/index.ts"],
      "houndex/providers": ["packages/core/src/providers/index.ts"],
      "houndex/storage": ["packages/core/src/storage/index.ts"],
      "houndex/storage/local": ["packages/storage-local/src/index.ts"],
      "houndex/storage/supabase": ["packages/storage-supabase/src/index.ts"],
      "houndex/storage/convex": ["packages/storage-convex/src/index.ts"],
      "houndex/tenant": ["packages/core/src/tenant.ts"],
      "houndex/identity": ["packages/core/src/identity.ts"],
      "houndex/models": ["packages/core/src/models.ts"],
      "houndex/observability": ["packages/core/src/observability.ts"],
      "houndex/pipeline": ["packages/pipeline/src/index.ts"],
      "houndex/evals": ["packages/evals/src/index.ts"],
      "houndex/connectors": ["packages/connectors/src/index.ts"],
      "houndex/cli": ["packages/cli/src/index.ts"],
      "houndex/cli/engine": ["packages/cli/src/engine.ts"]
    },
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  }
}
